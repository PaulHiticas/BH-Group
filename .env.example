# ============================================================
# BH Group PMS — Environment Variables
# Copy this file to .env and fill in real values before running
# docker compose up
# ============================================================

# --- PostgreSQL ---
POSTGRES_DB=bhgroup_pms
POSTGRES_USER=bhgroup
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_PORT=5432

# --- Backend (Spring Boot) ---
SPRING_PROFILES_ACTIVE=dev
BACKEND_PORT=8080
DB_URL=jdbc:postgresql://postgres:5432/bhgroup_pms
DB_USERNAME=bhgroup
DB_PASSWORD=change-me-strong-password

# JWT
JWT_SECRET=replace-with-a-base64-secret-of-at-least-64-bytes-in-production
JWT_ACCESS_TOKEN_EXPIRATION_MS=900000
JWT_REFRESH_TOKEN_EXPIRATION_MS=604800000

# Mail (SMTP)
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=replace-me
MAIL_PASSWORD=replace-me
MAIL_FROM=no-reply@bhgroup.io

# App
APP_BASE_URL=http://localhost:3000
APP_NAME=BH Group PMS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Bootstraps the first SUPER_ADMIN account on first startup (only if no SUPER_ADMIN exists yet)
SUPER_ADMIN_EMAIL=admin@bhgroup.io
SUPER_ADMIN_PASSWORD=change-me-strong-password

# File storage (property photos/documents)
UPLOAD_DIR=/data/uploads
UPLOAD_PUBLIC_BASE_URL=http://localhost:8080/uploads

# --- Frontend (Next.js) ---
FRONTEND_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1
